# ============================================================
# Highland Oak — Frontend Environment Variables
# ============================================================
# Copy this file to `.env` and fill in values for your environment.
# When BOTH variables are empty/unset, the app runs in mock mode
# with built-in seed data (no AWS backend required).
# ============================================================

# -----------------------------------------------------------
# VITE_API_URL — Backend API endpoint
# -----------------------------------------------------------
# Local development (default): points to the local dev server
# Production: use the ApiUrl value from SAM Stack Outputs
#   → Run: aws cloudformation describe-stacks --stack-name highland-oak-prod \
#           --query "Stacks[0].Outputs[?OutputKey=='ApiUrl'].OutputValue" --output text
VITE_API_URL=http://localhost:3001

# -----------------------------------------------------------
# VITE_CDN_URL — CloudFront CDN URL for serving images
# -----------------------------------------------------------
# Local development: leave empty (images served locally or via mock)
# Production: use the CloudFrontDomain value from SAM Stack Outputs
#   → Run: aws cloudformation describe-stacks --stack-name highland-oak-prod \
#           --query "Stacks[0].Outputs[?OutputKey=='CloudFrontDomain'].OutputValue" --output text
VITE_CDN_URL=

# ============================================================
# Production examples (replace with your actual Stack Output values after `sam deploy`):
#   VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
#   VITE_CDN_URL=https://d111111abcdef8.cloudfront.net
# ============================================================
