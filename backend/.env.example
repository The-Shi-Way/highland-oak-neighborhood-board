# ============================================================
# Highland Oak — Backend Environment Variables
# ============================================================
# Copy this file to `.env` and fill in values for local development.
# These variables are used by SAM Local (`sam local start-api`).
# In production, they are set automatically by the SAM template
# (Globals.Function.Environment.Variables) — no .env file needed.
# ============================================================

# -----------------------------------------------------------
# STAGE — Deployment stage
# -----------------------------------------------------------
# Controls resource naming and conditional logic (e.g., WAF is prod-only).
# Values: dev | prod
STAGE=dev

# -----------------------------------------------------------
# TABLE_NAME — DynamoDB table name
# -----------------------------------------------------------
# Stack Output: TableName
#   → Run: aws cloudformation describe-stacks --stack-name highland-oak-prod \
#           --query "Stacks[0].Outputs[?OutputKey=='TableName'].OutputValue" --output text
TABLE_NAME=CommunityBoard-dev

# -----------------------------------------------------------
# IMAGES_BUCKET — S3 bucket for user-uploaded images
# -----------------------------------------------------------
# Stack Output: ImagesBucketName
#   → Run: aws cloudformation describe-stacks --stack-name highland-oak-prod \
#           --query "Stacks[0].Outputs[?OutputKey=='ImagesBucketName'].OutputValue" --output text
IMAGES_BUCKET=highland-oak-images-dev

# -----------------------------------------------------------
# USER_POOL_ID — Cognito User Pool ID
# -----------------------------------------------------------
# Stack Output: UserPoolId
#   → Run: aws cloudformation describe-stacks --stack-name highland-oak-prod \
#           --query "Stacks[0].Outputs[?OutputKey=='UserPoolId'].OutputValue" --output text
USER_POOL_ID=us-east-1_XXXXXXXXX

# -----------------------------------------------------------
# USER_POOL_CLIENT_ID — Cognito User Pool Client ID
# -----------------------------------------------------------
# Stack Output: UserPoolClientId
#   → Run: aws cloudformation describe-stacks --stack-name highland-oak-prod \
#           --query "Stacks[0].Outputs[?OutputKey=='UserPoolClientId'].OutputValue" --output text
USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------
# ALLOWED_ORIGIN — CORS allowed origin
# -----------------------------------------------------------
# Local development: your frontend dev server URL
# Production: the CloudFront domain or your custom domain
ALLOWED_ORIGIN=http://localhost:3002

# -----------------------------------------------------------
# CLOUDFRONT_DOMAIN — CloudFront distribution URL
# -----------------------------------------------------------
# Stack Output: CloudFrontDomain
#   → Run: aws cloudformation describe-stacks --stack-name highland-oak-prod \
#           --query "Stacks[0].Outputs[?OutputKey=='CloudFrontDomain'].OutputValue" --output text
CLOUDFRONT_DOMAIN=https://dXXXXXXXXXXX.cloudfront.net

# -----------------------------------------------------------
# AWS_REGION — AWS region for all services
# -----------------------------------------------------------
# Must be us-east-1 if using CloudFront + WAF (WAF requires us-east-1 scope).
AWS_REGION=us-east-1

# ============================================================
# Production values come from SAM Stack Outputs after running:
#   sam build --use-container && sam deploy --guided
#
# To retrieve all outputs at once:
#   aws cloudformation describe-stacks --stack-name highland-oak-prod \
#       --query "Stacks[0].Outputs" --output table
# ============================================================
